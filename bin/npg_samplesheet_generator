#!/usr/bin/env perl

use strict;
use warnings;
use FindBin qw($Bin);
use lib ( -d "$Bin/../lib/perl5" ? "$Bin/../lib/perl5" : "$Bin/../lib" );
use Try::Tiny;
use English;
use Log::Log4perl qw(:levels);
use Pod::Usage;
use Getopt::Long;

use npg::samplesheet;
use st::api::lims;
use WTSI::DNAP::Warehouse::Schema;

our $VERSION = '0';

Log::Log4perl->easy_init({layout => '%d %-5p %c - %m%n',
                          level  => $INFO,
                          utf8   => 1});
my $id_run;
my $path;

GetOptions (
  'help' => sub { pod2usage(-verbose => 1, -exitval => 0) },
  'id_run=i' => \$id_run,
  'path=s'   => \$path
) or pod2usage(-message => "Error in command line arguments\n",
               -verbose => 1, -exitval => 1);

my $logger = Log::Log4perl->get_logger('main');

my $schema = WTSI::DNAP::Warehouse::Schema->connect();

my $rs_names2drivers = {
  'UseqRunMetric' => 'useq_ml_warehouse',
  'EseqRunLaneMetric' => 'eseq_ml_warehouse',
  'IseqRunLaneMetric' => 'ml_warehouse_auto'
};

my $driver_type;
foreach my $rs_name (keys %{$rs_names2drivers}) {
  if ($schema->resultset($rs_name)->search({id_run => $id_run})->count()) {
    $driver_type = $rs_names2drivers->{$rs_name};
    last;
  }
} 
 
if ($driver_type) {
  $logger->info("Using $driver_type driver type");
} else {
  $logger->error("Data for run $id_run is not available in MLWH");
  exit 1;
}

if (-f $path) {
  my $backup = "${path}.back";
  $logger->info("$path exists, will be moved out of the way to $backup");
  my $result = rename $path, $backup;
  if (!$result) {
    $logger->warn("Failed to move $path to $backup out of the way: $OS_ERROR");
  }
}

my $ref = {
  mlwh_schema => $schema,
  driver_type => $driver_type,
  id_run      => $id_run
};
if ($driver_type eq 'useq_ml_warehouse') {
  $ref->{position} = 1;
}

try {
  npg::samplesheet->new(
    id_run => $id_run,
    lims   => [st::api::lims->new($ref)->children()],
    extend => 1,
    output => $path,
  )->process();
} catch {
  my $error = $_;
  $logger->error("Failed to generate a samplesheet for run $id_run: $error");
  exit 1;
};

$logger->info("Samplesheet for run $id_run is written to $path");

1;

__END__

=head1 NAME

 npg_samplesheet_generator

=head1 USAGE

 npg_samplesheet_generator --id_run 3456 --path 3456_samplesheet.csv

=head1 REQUIRED ARGUMENTS

=head1 OPTIONS

 --id_run NPG tracking run ID
 
 --path   the path for the samplesheet, including the file name
 
=head1 DESCRIPTION

 Creates an extended NPG samplesheet for a sequencing run. Automatically
 detects the appropriate driver type. The run data should be available in one
 of platform-specific NPG MLWH tables.

 If a file exists at a given path, tries to move it out of the way.

=head1 EXIT STATUS

 0

=head1 DIAGNOSTICS

=head1 CONFIGURATION AND ENVIRONMENT

=head1 DEPENDENCIES

=over

=item strict

=item warnings

=item FindBin

=item lib

=item Log::Log4perl

=item Pod::Usage

=item Getopt::Long

=item st::api::lims

=item npg::samplesheet

=item WTSI::DNAP::Warehouse::Schema

=back

